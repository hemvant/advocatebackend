NODE_ENV=development
PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=advocatelearn_dev

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

# Redis (optional; enables cache + BullMQ for reminders, email, reports)
# REDIS_ENABLED=true
# REDIS_URL=redis://localhost:6379
# Or: REDIS_HOST=localhost REDIS_PORT=6379 REDIS_PASSWORD=

# Logging
# LOG_LEVEL=info
# LOG_DIR=./logs
# LOG_FILE=false

# Document uploads (optional)
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE_MB=10

# Optional: used by seeders for default super admin (only if none exists)
# SUPER_ADMIN_EMAIL=superadmin@advocatelearn.com
# SUPER_ADMIN_PASSWORD=SuperAdmin@123

# Payment gateway (Razorpay). If both are set, real payments are used; otherwise mock payments (success with random/static IDs).
# When enabling real payments: set both below and run npm install razorpay.
# RAZORPAY_KEY_ID=rzp_test_xxxx
# RAZORPAY_KEY_SECRET=xxxx

# eCourts case status sync (optional). If ECOURTS_API_URL is set, sync uses real API; otherwise mock success.
# API is called with GET and ?cnr=<CNR>. Response is expected to include status, next_hearing_date, court_no, stage (or camelCase / nested in .data).
# ECOURTS_API_URL=https://api.ecourts.example.com/v1/case/status
# ECOURTS_API_KEY=your-api-key-if-required

# WhatsApp Business API (optional). When set, real API is used; otherwise messages are mocked (logged, no send).
# WHATSAPP_API_URL=https://graph.facebook.com/v17.0
# WHATSAPP_ACCESS_TOKEN=your-token
# WHATSAPP_PHONE_ID=your-phone-number-id

# Servam/Sarvam AI (optional). When set, OCR extraction, case summary and draft generator use real API; otherwise static/mock flow.
# SERVAM_AI_API_URL=https://api.sarvam.ai/v1/chat/completions
# SERVAM_AI_API_KEY=your-sarvam-api-key
